{
  "name": "affected-codeowners",
  "description": "GitHub Action to determine which `CODEOWNERS` are affected based on changes in a pull request.",
  "version": "2.0.0",
  "author": "meddevo",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/meddevo/affected-codeowners",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meddevo/affected-codeowners.git"
  },
  "bugs": {
    "url": "https://github.com/meddevo/affected-codeowners/issues"
  },
  "keywords": [
    "github",
    "actions",
    "codeowners",
    "pull-requests"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "local-action": "npx @github/local-action . src/main.ts .env",
    "package": "npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run coverage && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@github/local-action": "^3.1.1",
    "@jest/globals": "^30.4.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.9.5",
    "prettier-eslint": "^16.3.0",
    "rollup": "^4.62.2",
    "rollup-plugin-delete": "^3.0.0",
    "ts-jest": "^29.4.11",
    "ts-jest-resolver": "^2.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "volta": {
    "node": "24.18.0"
  }
}
